{
  "rewrites": [
    {
      "source": "/session/:slug",
      "destination": "/api/session/:slug"
    },
    {
      "source": "/coach/:slug",
      "destination": "/api/coach/:slug"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
